      "--color-neon-blue": "#00F3FF",
      "--color-neon-pink": "#FF00FF",
      "--color-deep-space": "#0A0A0F",
      "--color-dark-slate": "#1A1A2E",
      "--font-heading": "'Orbitron', sans-serif",
      "--font-body": "'Rajdhani', sans-serif",
      "--spacing-unit": "8px"
    }
  }
